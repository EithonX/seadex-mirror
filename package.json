{
  "name": "seadex-mirror",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:site": "npm run data:build && npm run build",
    "data:build": "node scripts/build-static-data.mjs",
    "dev": "vite",
    "dev:pages": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:full": "npm run build:site && wrangler pages deploy dist",
    "typecheck": "tsc -p tsconfig.frontend.json --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "typescript": "latest",
    "vite": "^7.2.1",
    "wrangler": "^4.93.0"
  }
}
