{
  "name": "seadex-mirror",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:site",
    "build:frontend": "vite build",
    "build:site": "npm run data:build -- --onUnchanged=materialize && npm run build:frontend",
    "data:build": "node scripts/build-static-data.mjs",
    "data:sync-live": "node scripts/sync-live-mirror-data.mjs",
    "dev": "vite",
    "dev:pages": "wrangler pages dev dist",
    "deploy": "npm run build:site && wrangler pages deploy dist --project-name seadex",
    "deploy:full": "npm run data:build -- --force=true --onUnchanged=materialize && npm run build:frontend && wrangler pages deploy dist --project-name seadex",
    "typecheck": "tsc -p tsconfig.frontend.json --noEmit",
    "verify:deployed-site": "node scripts/verify-deployed-site.mjs",
    "verify:frontend-build": "node scripts/verify-frontend-build.mjs",
    "verify:mirror-data": "node scripts/verify-mirror-data.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "typescript": "latest",
    "vite": "^7.3.6",
    "wrangler": "^4.113.0"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  },
  "overrides": {
    "uuid": "11.1.1",
    "sharp": "^0.35.0"
  }
}
